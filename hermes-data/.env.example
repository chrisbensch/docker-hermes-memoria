# Optional Hermes runtime secrets.
# Copy this file to hermes-data/.env if you want Hermes itself to read
# provider keys from /opt/data/.env inside the container.
#
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# OPENROUTER_API_KEY=
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
#
# LM Studio local server. Leave LM_API_KEY empty unless LM Studio auth is on.
# For LM Studio on the Docker host, use host.docker.internal.
# LM_BASE_URL=http://host.docker.internal:1234/v1
# LM_API_KEY=

# Web access backends configured by setup.sh.
# Hermes uses Compose service names for internal web backends.
# FIRECRAWL_API_URL=http://firecrawl-api:3002
# CAMOFOX_URL=http://camofox:9377

# Shared Obsidian-compatible vault mounted inside Hermes.
OBSIDIAN_VAULT_PATH=/opt/data/obsidian-memory-vault
