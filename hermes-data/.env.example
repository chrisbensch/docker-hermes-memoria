# Optional Hermes runtime secrets.
# Copy this file to hermes-data/.env if you want Hermes itself to read
# provider keys from /opt/data/.env inside the container.
#
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# OPENROUTER_API_KEY=
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
#
# LM Studio local server. Leave LM_API_KEY empty unless LM Studio auth is on.
# LM_BASE_URL=http://127.0.0.1:1234/v1
# LM_API_KEY=
