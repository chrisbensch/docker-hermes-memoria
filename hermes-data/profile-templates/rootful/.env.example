# Copy this file to .env inside the profile directory if this profile needs
# profile-local provider keys or tool settings.
#
# The Hindsight bank is selected by config.yaml, not this env file.
HINDSIGHT_BANK_ID=__BANK_ID__

# Shared Obsidian-compatible vault mounted inside Hermes.
OBSIDIAN_VAULT_PATH=__OBSIDIAN_VAULT_PATH__

# Optional profile-local provider placeholders.
# DEEPSEEK_API_KEY=
# LM_BASE_URL=http://127.0.0.1:1234/v1
# LM_API_KEY=

# Web access backends for Hermes running with host networking.
FIRECRAWL_API_URL=http://127.0.0.1:3002
CAMOFOX_URL=http://127.0.0.1:9377
