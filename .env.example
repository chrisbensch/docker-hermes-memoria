# Copy this file to .env and edit it before running docker compose.
#
# On the Ubuntu host, set these to the account that should own files under
# ./appdata. Usually:
#   HERMES_UID=$(id -u)
#   HERMES_GID=$(id -g)
HERMES_UID=1000
HERMES_GID=1000
HERMES_HOME_MODE=0755

# Hermes Agent image.
HERMES_IMAGE=nousresearch/hermes-agent:latest
HERMES_API_BIND_HOST=127.0.0.1
HERMES_API_HOST_PORT=8642
HERMES_DASHBOARD_BIND_HOST=127.0.0.1
HERMES_DASHBOARD_HOST_PORT=9119

# For rootless Docker, set this to the deployment user's Docker socket.
# Usually:
#   DOCKER_SOCK=/run/user/$(id -u)/docker.sock
DOCKER_SOCK=/run/user/1000/docker.sock

# Portable app data directory. Hermes runtime state and each stateful sidecar
# store data under this directory instead of Docker-managed named volumes.
APPDATA_DIR=./appdata

# Hindsight MCP sidecar.
# The official Hindsight image exposes HTTP MCP at /mcp/ on API port 8888.
HINDSIGHT_IMAGE=ghcr.io/vectorize-io/hindsight:latest
HINDSIGHT_API_BIND_HOST=127.0.0.1
HINDSIGHT_API_HOST_PORT=8888
HINDSIGHT_UI_BIND_HOST=127.0.0.1
HINDSIGHT_UI_HOST_PORT=9999
HINDSIGHT_API_LLM_PROVIDER=openai
HINDSIGHT_API_LLM_MODEL=gpt-4o-mini
HINDSIGHT_API_LLM_API_KEY=
HINDSIGHT_API_LLM_BASE_URL=
HINDSIGHT_API_LOG_LEVEL=info
HINDSIGHT_API_WORKER_ID=hindsight-mcp

# Local LM Studio example for Hindsight running in Docker. Start LM Studio's
# local server on the host, then use host.docker.internal from the container:
# HINDSIGHT_API_LLM_PROVIDER=lmstudio
# HINDSIGHT_API_LLM_MODEL=your-local-model
# HINDSIGHT_API_LLM_BASE_URL=http://host.docker.internal:1234/v1
# HINDSIGHT_API_LLM_API_KEY=
#
# DeepSeek example for Hindsight:
# HINDSIGHT_API_LLM_PROVIDER=deepseek
# HINDSIGHT_API_LLM_MODEL=deepseek-chat
# HINDSIGHT_API_LLM_API_KEY=sk-your-deepseek-key

# Headroom proxy plus Docker-backed stdio MCP server.
HEADROOM_IMAGE=ghcr.io/chopratejas/headroom:0.27.0
HEADROOM_PROXY_BIND_HOST=127.0.0.1
HEADROOM_PROXY_HOST_PORT=8787
HEADROOM_TELEMETRY=off

# Optional: set when you want the Headroom proxy to forward to an upstream
# OpenAI-compatible endpoint.
# Example for LM Studio on the Docker host:
# OPENAI_TARGET_API_URL=http://host.docker.internal:1234/v1
OPENAI_TARGET_API_URL=

# Integrated web access stack: Firecrawl + SearXNG + Camofox.
# setup.sh clones Firecrawl source into FIRECRAWL_SOURCE_DIR so the patched
# nuq-postgres image can be built locally.
FIRECRAWL_IMAGE=ghcr.io/firecrawl/firecrawl:latest
FIRECRAWL_PLAYWRIGHT_IMAGE=ghcr.io/firecrawl/playwright-service:latest
FIRECRAWL_SOURCE_DIR=./.firecrawl-src
FIRECRAWL_BIND_HOST=127.0.0.1
FIRECRAWL_HOST_PORT=3002
FIRECRAWL_USE_DB_AUTHENTICATION=false
FIRECRAWL_POSTGRES_USER=postgres
FIRECRAWL_POSTGRES_PASSWORD=
FIRECRAWL_POSTGRES_DB=postgres
FIRECRAWL_BULL_AUTH_KEY=

SEARXNG_IMAGE=searxng/searxng:latest
SEARXNG_NGINX_IMAGE=nginx:alpine
SEARXNG_SETTINGS_FILE=./web-search/searxng-settings.yml
SEARXNG_BIND_HOST=127.0.0.1
SEARXNG_HOST_PORT=8889

CAMOFOX_IMAGE=ghcr.io/jo-inc/camofox-browser:latest
CAMOFOX_BIND_HOST=127.0.0.1
CAMOFOX_HOST_PORT=9377
